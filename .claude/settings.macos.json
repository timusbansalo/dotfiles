{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "desktop-commander@claude-plugins-official": true
  },
  "theme": "light",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "bash __HOME__/dotfiles/.claude/omni-statusline.sh",
    "refreshInterval": 300
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOME__/dotfiles/.claude/omni-banner.sh",
            "timeout": 10,
            "statusMessage": "Loading workspace status..."
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ -e /dev/tty ] && bash __HOME__/dotfiles/.claude/hooks/approval-banner.sh > /dev/tty 2>&1 || true'"
          },
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Funk.aiff; osascript -e 'display notification \"Claude wants to run something\" with title \"Claude Code\" subtitle \"Approval needed\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ -e /dev/tty ] && bash __HOME__/dotfiles/.claude/hooks/input-banner.sh > /dev/tty 2>&1 || true'"
          },
          {
            "type": "command",
            "command": "afplay /System/Library/Sounds/Glass.aiff; osascript -e 'display notification \"Read the output and reply\" with title \"Claude Code\" subtitle \"Your turn\"'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(*)",
      "Edit(__HOME__/Downloads/Claude/**)",
      "Write(__HOME__/Downloads/Claude/**)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(brew *)",
      "Bash(python3 *)",
      "Bash(ls *)",
      "Bash(ll *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(echo *)",
      "Bash(open *)",
      "Bash(curl *)",
      "Bash(pbpaste *)",
      "Bash(pbcopy *)",
      "Bash(which *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(less *)",
      "Bash(wc *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(diff *)",
      "Bash(date *)",
      "Bash(env *)",
      "Bash(printenv *)",
      "Bash(source *)",
      "Bash(ssh prodvm2 *)",
      "Bash(ssh prodvm2)",
      "Bash(ssh-keyscan *)",
      "Bash(ssh-copy-id *)",
      "Bash(scp * prodvm2:*)",
      "Bash(scp prodvm2:* *)",
      "Bash(rsync * prodvm2:*)",
      "Bash(rsync prodvm2:* *)"
    ]
  }
}
